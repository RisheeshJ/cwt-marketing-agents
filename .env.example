# ============================================================
# CrowdWisdomTrading Marketing Agents — Environment Variables
# Copy this file to .env  ->  cp .env.example .env
# Then fill in your real keys. NEVER commit the real .env to git.
# ============================================================

# --- LLM provider (required) ---
# Get a key at https://openrouter.ai -> Keys -> Create Key
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx

# Which model the agents use (any OpenRouter model id works)
# Cheap + good default:
HERMES_MODEL=anthropic/claude-sonnet-4.6

# --- Apify (required for the Ads Manager agent) ---
# Get a token at https://console.apify.com -> Settings -> Integrations -> API tokens
APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxx

# The Apify "actor" (a ready-made scraper) that scrapes the Meta Ads Library.
# Search "facebook ads library scraper" in the Apify Store and paste its ID/slug here.
APIFY_ACTOR_ID=curious_coder/facebook-ads-library-scraper

# --- Obsidian vault (required) ---
# Absolute path to the vault folder (the `vault/` folder in this repo,
# opened in Obsidian). Example (Windows WSL): /home/you/cwt-marketing-agents/vault
OBSIDIAN_VAULT_PATH=/absolute/path/to/cwt-marketing-agents/vault

# --- Telegram (used by the Hermes gateway; set up via `hermes gateway setup`) ---
# Create a bot with @BotFather on Telegram and paste the token here.
TELEGRAM_BOT_TOKEN=123456:ABC-xxxxxxxxxxxxxxxx

# --- Search parameters for the Ads Manager ---
ADS_SEARCH_TERMS=stock trading,options trading,trading signals,copy trading
ADS_COUNTRY=US
ADS_MAX_RESULTS=40
